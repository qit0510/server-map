{
  "version": 8,
  "name": "Minimal (极简灰底)",
  "center": [
    104,
    35
  ],
  "zoom": 3,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:1234/api/tilesets/china/tilejson"
    }
  },
  "glyphs": "http://localhost:1234/api/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": {
        "background-color": "#f2f2f2"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#e8e8e8",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#e0e0e0",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#d8dce0"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "==",
        "class",
        "river"
      ],
      "paint": {
        "line-color": "#d8dce0",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          2
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#dcdcdc",
        "fill-outline-color": "#cccccc"
      }
    },
    {
      "id": "road_motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "==",
        "class",
        "motorway"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c0c0c0",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          4,
          14,
          10
        ]
      }
    },
    {
      "id": "road_trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "trunk",
        "primary"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#cccccc",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          3,
          14,
          6
        ]
      }
    },
    {
      "id": "road_secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "secondary",
        "tertiary"
      ],
      "paint": {
        "line-color": "#d8d8d8",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1,
          14,
          4
        ]
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "city",
        "town"
      ],
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          10,
          10,
          16
        ]
      },
      "paint": {
        "text-color": "#666666",
        "text-halo-color": "rgba(242,242,242,0.8)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "village",
        "hamlet",
        "suburb"
      ],
      "minzoom": 10,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 9
      },
      "paint": {
        "text-color": "#888888",
        "text-halo-color": "rgba(242,242,242,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "admin_level",
        2
      ],
      "minzoom": 1,
      "paint": {
        "line-color": "#aaaaaa",
        "line-width": 0.5,
        "line-dasharray": [
          6,
          3
        ]
      }
    }
  ],
  "id": "minimal"
}