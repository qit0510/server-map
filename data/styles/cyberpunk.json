{
  "version": 8,
  "name": "Cyberpunk (赛博朋克)",
  "center": [
    104,
    35
  ],
  "zoom": 3,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:1234/api/tilesets/china/tilejson"
    }
  },
  "sprite": "http://localhost:1234/api/sprites/streets/sprite",
  "glyphs": "http://localhost:1234/api/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": {
        "background-color": "#050510"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#0a0a20",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "class",
        "wood"
      ],
      "paint": {
        "fill-color": "#002210",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "landcover_grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "class",
        "grass"
      ],
      "paint": {
        "fill-color": "#001a10",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#001030"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "==",
        "class",
        "river"
      ],
      "paint": {
        "line-color": "#001030",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          3
        ]
      }
    },
    {
      "id": "water_name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "minzoom": 7,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 11
      },
      "paint": {
        "text-color": "#00aaff",
        "text-halo-color": "rgba(5,5,16,0.9)",
        "text-halo-width": 1
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#100820",
        "fill-outline-color": "#200840"
      }
    },
    {
      "id": "road_motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "==",
        "class",
        "motorway"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ff0088",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          5,
          14,
          12
        ],
        "line-blur": 1
      }
    },
    {
      "id": "road_motorway_glow",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "==",
        "class",
        "motorway"
      ],
      "layout": {
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#ff0088",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          3,
          14,
          14
        ],
        "line-opacity": 0.15,
        "line-blur": 3
      }
    },
    {
      "id": "road_trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "trunk",
        "primary"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#cc00aa",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          3,
          14,
          8
        ],
        "line-blur": 0.5
      }
    },
    {
      "id": "road_secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "secondary",
        "tertiary"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0066cc",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          2,
          16,
          5
        ]
      }
    },
    {
      "id": "road_minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "minor",
        "service",
        "track"
      ],
      "minzoom": 13,
      "paint": {
        "line-color": "#002244",
        "line-width": 0.8
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "city",
        "town"
      ],
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          10,
          10,
          16
        ]
      },
      "paint": {
        "text-color": "#00ffcc",
        "text-halo-color": "rgba(5,5,16,0.9)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "village",
        "hamlet",
        "suburb"
      ],
      "minzoom": 10,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 9
      },
      "paint": {
        "text-color": "#00cc88",
        "text-halo-color": "rgba(5,5,16,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 9,
        "text-anchor": "top",
        "text-offset": [
          0,
          0.8
        ],
        "icon-image": [
          "concat",
          [
            "coalesce",
            [
              "get",
              "class"
            ],
            [
              "get",
              "subclass"
            ],
            "circle"
          ],
          "-15"
        ],
        "icon-size": 0.5,
        "icon-allow-overlap": true
      },
      "paint": {
        "text-color": "#00ddbb",
        "text-halo-color": "rgba(5,5,16,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "admin_level",
        2
      ],
      "minzoom": 1,
      "paint": {
        "line-color": "#003355",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          3,
          0.5,
          6,
          1.5
        ],
        "line-dasharray": [
          6,
          3
        ]
      }
    },
    {
      "id": "aeroway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "filter": [
        "==",
        "class",
        "runway"
      ],
      "minzoom": 10,
      "paint": {
        "line-color": "#001133",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1,
          14,
          4
        ]
      }
    }
  ],
  "id": "cyberpunk"
}