{
  "version": 8,
  "name": "Dark (暗黑大屏)",
  "center": [
    104,
    35
  ],
  "zoom": 3,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:1234/api/tilesets/china/tilejson"
    }
  },
  "sprite": "http://localhost:1234/api/sprites/streets/sprite",
