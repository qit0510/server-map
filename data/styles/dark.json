      "source-layer": "water_name",
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "minzoom": 7,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
