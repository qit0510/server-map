      "filter": [
        "==",
        "class",
        "river"
      ],
      "paint": {
        "line-color": "#0d1b2a",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          3
        ]
      }
    },
    {
