{
  "version": 8,
  "name": "Satellite (卫星地球)",
  "center": [
    104,
    35
  ],
  "zoom": 3,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:1234/api/tilesets/china/tilejson"
    }
  },
  "sprite": "http://localhost:1234/api/sprites/streets/sprite",
  "glyphs": "http://localhost:1234/api/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": {
        "background-color": "#e8e0d0"
      }
    },
    {
      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "residential"
      ],
      "paint": {
        "fill-color": "#e0d4be",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse_industrial",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "industrial"
      ],
      "paint": {
        "fill-color": "#d8ccb5",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landcover_wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "class",
        "wood"
      ],
      "paint": {
        "fill-color": "#90a878",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landcover_grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "class",
        "grass"
      ],
      "paint": {
        "fill-color": "#a8b888",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "landcover_crop",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": [
        "==",
        "class",
        "crop"
      ],
      "paint": {
        "fill-color": "#c8b878",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#98b080",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#98b8d0"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "==",
        "class",
        "river"
      ],
      "paint": {
        "line-color": "#98b8d0",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          3
        ]
      }
    },
    {
      "id": "water_name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "filter": [
        "==",
        "$type",
        "Point"
      ],
      "minzoom": 7,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 11
      },
      "paint": {
        "text-color": "#4a7088",
        "text-halo-color": "rgba(232,224,208,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#ccc0a8",
        "fill-outline-color": "#b8ac94"
      }
    },
    {
      "id": "road_motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "==",
        "class",
        "motorway"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0c070",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          5,
          14,
          12
        ]
      }
    },
    {
      "id": "road_trunk",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "trunk",
        "primary"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f8d888",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          1,
          10,
          3,
          14,
          8
        ]
      }
    },
    {
      "id": "road_secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "secondary",
        "tertiary"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f0e8d8",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          8,
          1,
          12,
          2,
          16,
          6
        ]
      }
    },
    {
      "id": "road_minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "in",
        "class",
        "minor",
        "service",
        "track",
        "path"
      ],
      "minzoom": 13,
      "paint": {
        "line-color": "#d8d0c0",
        "line-width": 0.8
      }
    },
    {
      "id": "place_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "city",
        "town"
      ],
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          5,
          10,
          10,
          16
        ]
      },
      "paint": {
        "text-color": "#4a3a2a",
        "text-halo-color": "rgba(232,224,208,0.8)",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place_village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "in",
        "class",
        "village",
        "hamlet",
        "suburb"
      ],
      "minzoom": 10,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 9
      },
      "paint": {
        "text-color": "#5a4a3a",
        "text-halo-color": "rgba(232,224,208,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "minzoom": 14,
      "layout": {
        "text-field": [
          "coalesce",
          [
            "get",
            "name:zh"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Arial Unicode MS Regular"
        ],
        "text-size": 9,
        "text-anchor": "top",
        "text-offset": [
          0,
          0.8
        ],
        "icon-image": [
          "concat",
          [
            "coalesce",
            [
              "get",
              "class"
            ],
            [
              "get",
              "subclass"
            ],
            "circle"
          ],
          "-15"
        ],
        "icon-size": 0.5,
        "icon-allow-overlap": true
      },
      "paint": {
        "text-color": "#5a4a3a",
        "text-halo-color": "rgba(232,224,208,0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [
        "==",
        "admin_level",
        2
      ],
      "minzoom": 1,
      "paint": {
        "line-color": "#b0a090",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          3,
          0.5,
          6,
          1.5
        ],
        "line-dasharray": [
          6,
          3
        ]
      }
    },
    {
      "id": "aeroway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "aeroway",
      "filter": [
        "==",
        "class",
        "runway"
      ],
      "minzoom": 10,
      "paint": {
        "line-color": "#c8c0b0",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          1,
          14,
          4
        ]
      }
    }
  ],
  "id": "satellite"
}