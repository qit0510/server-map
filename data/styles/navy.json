      "id": "landuse_residential",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": [
        "==",
        "class",
        "residential"
      ],
      "paint": {
        "fill-color": "#071232",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse_industrial",
