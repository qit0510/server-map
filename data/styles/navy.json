{
  "version": 8,
  "name": "Navy (海军蓝指挥大屏)",
  "center": [
    104,
    35
  ],
  "zoom": 3,
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "http://localhost:1234/api/tilesets/china/tilejson"
    }
  },
  "sprite": "http://localhost:1234/api/sprites/streets/sprite",
  "glyphs": "http://localhost:1234/api/fonts/{fontstack}/{range}.pbf",
